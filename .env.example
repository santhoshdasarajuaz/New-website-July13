## Niaga Prestasi Website (example env)
## Copy to .env.local for local development.
##
## Do NOT commit real secrets.

# Public site URL (optional; used for canonical URLs/sitemap if added later)
VITE_PUBLIC_SITE_URL=http://localhost:5173

## Contact providers (optional — only needed when switching away from FormSubmit)
## See docs/CONTACT_PROVIDERS.md
# VITE_WEB3FORMS_ACCESS_KEY=
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_CONTACT_FUNCTION_URL=
# VITE_CONTACT_WORKER_URL=
# VITE_CONTACT_API_URL=
