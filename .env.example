## Niaga Prestasi Website (example env)
## Copy to .env.local for local development.
##
## Do NOT commit real secrets.

# Public site URL (optional; used for canonical URLs/sitemap if added later)
VITE_PUBLIC_SITE_URL=http://localhost:5173

## SMTP (server-side) — required for contact form email routing
## Do NOT commit real credentials.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Niaga Prestasi Website <no-reply@niagaprestasi.com>"

